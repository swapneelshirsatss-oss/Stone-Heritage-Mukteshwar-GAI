---
import { testimonials } from '../../data/testimonials';
import { Image } from 'astro:assets';
---
<div class="py-16 px-4 max-w-7xl mx-auto bg-stone-50/50 min-h-screen">
  <div class="text-center mb-12">
    <h1 class="text-4xl md:text-5xl font-bold mb-4 text-primary tracking-tight">Guest Experiences</h1>
    <p class="text-lg text-primary/70 max-w-2xl mx-auto leading-relaxed">
      Read what our wonderful guests have to say about their stay at Stone Heritage Mukteshwar.
    </p>
  </div>

  <div class="flex justify-center mb-16">
    <div class="flex flex-col md:flex-row justify-center items-center gap-8 md:gap-16 bg-white w-fit p-6 md:px-12 rounded-2xl shadow-sm border border-stone-200">
      <div class="flex items-center gap-4">
        <div class="text-5xl font-black text-primary tracking-tighter">4.9</div>
        <div class="text-left">
          <div class="flex text-accent text-sm mb-1 gap-1">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <div class="text-sm font-medium text-primary/70">From 251+ Reviews</div>
        </div>
      </div>
      <div class="hidden md:block w-px h-16 bg-stone-200"></div>
      <div class="flex items-center gap-4">
        <div class="text-5xl font-black text-primary tracking-tighter">10k+</div>
        <div class="text-left">
          <div class="text-sm font-bold text-primary mb-1">Happy Guests</div>
          <div class="text-sm font-medium text-primary/70">Hosted at our property</div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {testimonials.map((testimonial) => (
      <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-200 flex flex-col items-center hover:shadow-xl hover:-translate-y-2 transition-all duration-300">
        <div class="w-24 h-24 bg-stone-200 rounded-full overflow-hidden mb-6 border-4 border-stone-50 shadow-sm flex-shrink-0">
          {testimonial.image ? (
            <Image 
              src={testimonial.image} 
              alt={`Portrait of guest ${testimonial.name}`} 
              class="w-full h-full object-cover"
              width={100}
              height={100}
              loading="lazy"
            />
          ) : (
            <div class="w-full h-full bg-stone-300 flex items-center justify-center text-stone-600 text-3xl font-bold uppercase">
              {testimonial.name.charAt(0)}
            </div>
          )}
        </div>
        <div class="flex text-accent mb-6 text-base gap-1">
          <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
        </div>
        <p class="text-primary/80 leading-relaxed text-center italic mb-8 text-base md:text-lg tracking-wide flex-grow">
          "{testimonial.text}"
        </p>
        <div class="text-center">
          <h3 class="text-lg font-bold text-primary">{testimonial.name}</h3>
          {testimonial.role && <p class="text-sm text-primary/60 mt-1">{testimonial.role}</p>}
        </div>
      </div>
    ))}
  </div>
</div>
