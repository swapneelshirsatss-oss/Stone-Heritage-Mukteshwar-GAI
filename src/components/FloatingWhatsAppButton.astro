---
import { MessageCircle } from 'lucide-react';
const whatsappNumber = "919027844424";
const whatsappUrl = `https://wa.me/${whatsappNumber}`;
---
<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-[72px] md:bottom-8 right-4 md:right-8 bg-[#25D366] text-white p-3 md:p-4 rounded-full shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 z-50 flex items-center justify-center group"
  aria-label="Contact us on WhatsApp"
>
  <MessageCircle className="w-6 h-6 md:w-8 md:h-8" />
  <!-- Tooltip for desktop -->
  <span class="absolute right-full mr-4 bg-gray-900 text-white text-sm py-1.5 px-3 rounded-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 whitespace-nowrap hidden md:block">
    Chat with us
    <!-- Triangle arrow -->
    <span class="absolute top-1/2 -right-1 -translate-y-1/2 border-4 border-transparent border-l-gray-900"></span>
  </span>
</a>
